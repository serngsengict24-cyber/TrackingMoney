<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    tools:context=".LoginActivity">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/economic"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Login account"
        android:textSize="38dp"
        android:gravity="center"
        android:textColor="#FF9800"
        android:textStyle="bold"
        />

    <EditText
        android:id="@+id/Email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/lavender_border"
        android:drawableLeft="@drawable/user"
        android:drawablePadding="10dp"
        android:hint="Email"
        android:inputType="text"
        android:outlineAmbientShadowColor="@color/black"
        android:padding="14dp"
        android:textColor="#5C5A5A"
        android:textSize="16dp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/Password"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="16dp"
    android:layout_marginEnd="10dp"
    android:background="@drawable/lavender_border" android:drawableLeft="@drawable/locked" android:drawablePadding="10dp"
    android:hint="Password"
    android:inputType="textPassword"
    android:padding="14dp"
    android:textColor="#5C5A5A"
    android:textSize="18dp"
    android:textStyle="bold" />

    <TextView
        android:id="@+id/LinkToSignUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Don't have account. Sign up "
        android:textSize="16dp"
        android:textColor="#0480DD"
        android:gravity="center"
        android:layout_marginTop="16dp"
        />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="@drawable/lavender_border"
        android:gravity="center"
        android:padding="8dp"
        android:text="Log in"
        android:textColor="#F9F9F9"
        android:textSize="18dp"
        android:textStyle="bold" />
</LinearLayout>
